# Papra connection
PAPRA_API_URL=http://papra:1221
PAPRA_API_KEY=ppapi_your_key_here
PAPRA_ORG_ID=org_your_org_id

# OCR vision model (any OpenAI-compatible API)
OCR_API_URL=https://openrouter.ai/api/v1
OCR_API_KEY=sk-or-v1-your_key_here
OCR_MODEL=google/gemini-2.5-flash

# Processing
OCR_CONCURRENCY=3
OCR_IMAGE_SCALE=2
OCR_POLL_INTERVAL_SECONDS=60

# Name format template. Placeholders are filled from document content.
# Default: "{sender} — {type} {detail}"
# OCR_NAME_FORMAT={sender} — {type} {detail}

# Set to false to skip OCR for existing documents on first run.
# Only documents uploaded after the service starts will be processed.
# Default: true (process all documents)
OCR_PROCESS_EXISTING=true

# State directory (persists processed document IDs)
DATA_DIR=./data

# Logging
LOG_LEVEL=info
